# Current AI provider for card generation/explanations
OPENAI_API_KEY=sk-...

# Legacy / optional providers
ANTHROPIC_API_KEY=sk-ant-...
OPENROUTER_API_KEY=sk-or-v1-...

# Default model
DEFAULT_MODEL=gpt-4o-mini

# Logging
LOG_LEVEL=INFO

# Timezone for local-date features such as study day, due cards, analytics heatmap
APP_TIMEZONE=Asia/Ho_Chi_Minh

# AI Hook Logging (set by instructor)
AI_LOG_SERVER=https://ai-logs.note.transformerlabs.ai/api/ingest
AI_LOG_API_KEY=lMfm8NPzHVHlOtYx2kOQ7c9PTxJOB0E3DJbD_UBlsFw
AI_LOG_DIR=.ai-log

# Docker deployment — set to the server's public IP or domain
# e.g. http://192.168.1.100:8000  or  https://api.yourdomain.com
NEXT_PUBLIC_API_URL=http://localhost:8000
DATABASE_URL=postgresql://

# Auth (JWT) — REQUIRED
# Generate a strong secret, e.g.:
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=replace_with_strong_random_secret

# Telegram bot (Learning Automation) — REQUIRED if enabling Study Buddy Bot
# Create a bot with @BotFather and paste the token here.
TELEGRAM_BOT_TOKEN=123456789:AA...your_bot_token_here

# Notion OAuth (required for Notion integration MVP)
# Create a public integration in Notion and set the redirect URI to:
#   http://localhost:8000/api/notion/callback
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
NOTION_REDIRECT_URI=http://localhost:8000/api/notion/callback
NOTION_FRONTEND_REDIRECT_URL=http://localhost:3000/integrations

OPENAI_IMAGE_ENABLED=true   # false để tắt DALL-E 3
